{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/PascalCase.Api/bin/Debug/net10.0/PascalCase.Api.dll",
      "cwd": "${workspaceFolder}/src/PascalCase.Api",
      "preLaunchTask": "build-api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Web",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/src/PascalCase.Web/bin/Debug/net10.0/PascalCase.Web.dll",
      "cwd": "${workspaceFolder}/src/PascalCase.Web",
      "preLaunchTask": "build-web",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": [
        "API",
        "Web"
      ]
    }
  ]
}